# Supabase principal usado por autenticación y tablas de la aplicación.
# Puedes obtenerlos en Supabase: Project Settings > API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase externo usado por las importaciones desde vistas remotas.
# Solo es necesario si usarás Configuración/Importación de datos externos.
VITE_EXT_SUPABASE_URL=https://your-external-project-ref.supabase.co
VITE_EXT_SUPABASE_ANON_KEY=your-external-supabase-anon-key
